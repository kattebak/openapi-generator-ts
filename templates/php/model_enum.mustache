class {{classname}}
{
    /**
     * Possible values of this enum
     */
    {{#allowableValues}}
    {{#enumVars}}
    {{#enumDescription}}
    /**
     * {{enumDescription}}
     */
    {{/enumDescription}}
    public const {{{name}}} = {{{value}}};

    {{/enumVars}}
    {{/allowableValues}}
    /**
     * Gets allowable values of the enum
     * @return string[]
     */
    public static function getAllowableEnumValues()
    {
        return [
            {{#allowableValues}}
            {{#enumVars}}
            self::{{{name}}}{{#unless @last}},
            {{/unless}}
            {{/enumVars}}
            {{/allowableValues}}

        ];
    }
}
